# GitHub Developer Ecosystem Analytics — Environment Variables
# Copy this file to .env and fill in your values before running docker-compose up
#
#   cp .env.example .env

# ---------------------------------------------------------------------------
# GitHub Personal Access Tokens (classic, read:public_repo scope)
# Each team member creates one at: https://github.com/settings/tokens
# Used by the streaming producer for PAT rotation (4 × 5000 = 20k req/hr)
# ---------------------------------------------------------------------------
PAT_HARIHARAN=ghp_your_hariharan_token_here
PAT_SHREYAS=ghp_your_shreyas_token_here
PAT_TANUSHA=ghp_your_tanusha_token_here
PAT_VIKRAM=ghp_your_vikram_token_here

# ---------------------------------------------------------------------------
# InfluxDB (set automatically by docker-compose — only change if needed)
# ---------------------------------------------------------------------------
INFLUXDB_TOKEN=github-analytics-token
INFLUXDB_ORG=github-analytics
INFLUXDB_BUCKET=github-stream
INFLUXDB_URL=http://localhost:8086

# ---------------------------------------------------------------------------
# PostgreSQL Analytics (set automatically by docker-compose)
# ---------------------------------------------------------------------------
POSTGRES_ANALYTICS_HOST=localhost
POSTGRES_ANALYTICS_PORT=5433
POSTGRES_ANALYTICS_DB=github_analytics
POSTGRES_ANALYTICS_USER=analytics
POSTGRES_ANALYTICS_PASSWORD=analytics
